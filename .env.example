APP_PORT=8080
APP_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=realworld
DB_SSLMODE=disable

JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=72

# Redis (optional — app falls back to no-op cache if Redis is unavailable)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Mail (MailHog for local dev — http://localhost:8025 for web UI)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@realworld.dev
MAIL_USERNAME=
MAIL_PASSWORD=
